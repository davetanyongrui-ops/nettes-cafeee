import Link from 'next/link'
import { createClient } from '@/lib/supabase/server'
import { toSettingsMap, getSetting } from '@/types/database'
import { ArrowRight, Leaf, HeartPulse, Sparkles } from 'lucide-react'
import EditableText from '@/components/EditableText'

export default async function HomePage() {
  const supabase = await createClient()
  const { data } = await supabase.from('site_settings').select('key, value')
  const s = toSettingsMap(data ?? [])

  const features = [
    { icon: <Leaf className="text-emerald-600" size={30} />, titleKey: 'home_feature1_title', descKey: 'home_feature1_desc', titleFallback: 'Fresh Daily', descFallback: 'Ingredients sourced locally every morning.' },
    { icon: <HeartPulse className="text-emerald-600" size={30} />, titleKey: 'home_feature2_title', descKey: 'home_feature2_desc', titleFallback: 'Healing Broths', descFallback: 'Slow-cooked for maximum nutrition.' },
    { icon: <Sparkles className="text-emerald-600" size={30} />, titleKey: 'home_feature3_title', descKey: 'home_feature3_desc', titleFallback: 'Zero Cream', descFallback: 'Flavour from robust, natural stocks.' },
  ]

  return (
    <div className="flex flex-col w-full">
      {/* ═══ Hero ═══════════════════════════════════════════════════════════ */}
      <section className="relative w-full min-h-[600px] flex items-center overflow-hidden bg-emerald-950">
        <div className="absolute inset-0 bg-gradient-to-r from-emerald-950 via-emerald-900/70 to-transparent z-10" />
        <div
          className="absolute inset-0 opacity-30 bg-cover bg-center"
          style={{ backgroundImage: "url('https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=2680&auto=format&fit=crop')" }}
        />
        <div className="relative z-20 max-w-6xl mx-auto px-6 sm:px-8 py-24 flex flex-col items-start gap-7">
          {/* Badge / Tagline */}
          <span className="px-4 py-1.5 rounded-full bg-emerald-800/60 text-emerald-100 text-sm font-semibold backdrop-blur-md border border-emerald-700/40 flex items-center gap-2">
            <Leaf size={14} />
            <EditableText
              settingKey="cafe_tagline"
              initialValue={getSetting(s, 'cafe_tagline', 'Nourishing Hospital Staff & Patients')}
              className="text-emerald-100 text-sm font-semibold"
            />
          </span>

          {/* Hero Title */}
          <h1 className="text-5xl md:text-8xl font-serif text-emerald-950 leading-tight tracking-tight max-w-3xl">
            <EditableText
              settingKey="home_hero_title"
              initialValue={getSetting(s, 'home_hero_title', 'Healthy Food, Healing Power.')}
              className="text-5xl md:text-8xl font-serif text-emerald-950 leading-tight tracking-tight"
              wrapperClassName="w-full"
            />
          </h1>

          {/* Hero Subtitle */}
          <EditableText
            settingKey="home_hero_subtitle"
            initialValue={getSetting(s, 'home_hero_subtitle', 'Real ingredients, restorative broths, and salads designed to fuel your day.')}
            as="textarea"
            className="text-lg md:text-xl text-emerald-100 max-w-xl leading-relaxed font-medium"
            wrapperClassName="max-w-xl w-full"
          />

          {/* CTAs */}
          <div className="flex flex-wrap gap-4 mt-2">
            <Link href="/menu" className="px-8 py-4 rounded-3xl bg-orange-700 text-stone-50 font-bold hover:bg-orange-800 transition-all flex items-center gap-2 hover:gap-3 shadow-xl">
              <EditableText
                settingKey="home_cta_button"
                initialValue={getSetting(s, 'home_cta_button', 'Order Now')}
                className="font-bold text-stone-50"
              />
              <ArrowRight size={20} />
            </Link>
            <Link href="/about" className="px-8 py-4 rounded-full bg-emerald-800/70 text-white font-bold hover:bg-emerald-700 transition border border-emerald-700/50">
              Our Story
            </Link>
          </div>
        </div>
      </section>

      {/* ═══ Features ══════════════════════════════════════════════════════ */}
      <section className="py-24 bg-white">
        <div className="max-w-6xl mx-auto px-4 sm:px-6">
          <div className="text-center mb-16">
            <h2 className="text-4xl md:text-6xl font-serif text-emerald-900 tracking-tight">Why Choose Nette's?</h2>
            <p className="mt-4 text-stone-600 text-lg font-medium max-w-xl mx-auto">
              We believe hospital food should be the healthiest food in the world.
            </p>
          </div>
          <div className="grid md:grid-cols-4 md:grid-rows-2 gap-6">
            {features.map((f, i) => (
              <div key={i} className={`bg-stone-50 rounded-3xl p-8 border border-stone-200 hover:shadow-xl transition-shadow group ${i === 0 ? 'md:col-span-2 md:row-span-2' : 'md:col-span-2 md:row-span-1'}`}>
                <div className="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm mb-6 group-hover:scale-110 transition-transform border border-stone-100">
                  {f.icon}
                </div>
                <h3 className="text-2xl font-serif text-emerald-900 mb-3">
                  <EditableText
                    settingKey={f.titleKey}
                    initialValue={getSetting(s, f.titleKey, f.titleFallback)}
                    className="text-2xl font-serif text-emerald-900"
                    wrapperClassName="w-full"
                  />
                </h3>
                <EditableText
                  settingKey={f.descKey}
                  initialValue={getSetting(s, f.descKey, f.descFallback)}
                  as="textarea"
                  className="text-stone-600 leading-relaxed text-base"
                  wrapperClassName="w-full"
                />
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ═══ Bottom CTA ═══════════════════════════════════════════════════ */}
      <section className="py-24 bg-emerald-50 relative overflow-hidden">
        <div className="absolute -right-24 -top-24 w-96 h-96 bg-emerald-200/40 rounded-full blur-3xl pointer-events-none" />
        <div className="absolute -left-24 -bottom-24 w-96 h-96 bg-teal-200/40 rounded-full blur-3xl pointer-events-none" />
        <div className="max-w-3xl mx-auto px-4 text-center relative z-10">
          <h2 className="text-5xl md:text-6xl font-serif text-emerald-900 mb-4 tracking-tight">
            <EditableText
              settingKey="home_cta_title"
              initialValue={getSetting(s, 'home_cta_title', 'Ready to order?')}
              className="text-5xl md:text-6xl font-serif text-emerald-900 tracking-tight"
              wrapperClassName="inline-block"
            />
          </h2>
          <p className="text-lg text-emerald-800 mb-8 font-medium max-w-xl mx-auto">
            <EditableText
              settingKey="home_cta_subtitle"
              initialValue={getSetting(s, 'home_cta_subtitle', 'Choose eat-in or takeaway.')}
              as="textarea"
              className="text-lg text-emerald-800 font-medium"
              wrapperClassName="w-full"
            />
          </p>
          <Link href="/menu" className="px-10 py-5 text-lg rounded-3xl bg-orange-700 text-stone-50 font-bold hover:bg-orange-800 transition shadow-lg shadow-orange-900/20">
            Start Your Order
          </Link>
        </div>
      </section>
    </div>
  )
}
